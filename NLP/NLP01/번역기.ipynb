   "source": [
    "def texts_to_sequences(corpus, word2idx):\n",
    "\n",
    "    sequences = []\n",
    "\n",
    "    for sentence in corpus:\n",
    "\n",
    "        seq = [\n",
    "            word2idx.get(\n",
    "                word,\n",
    "                word2idx[\"<unk>\"]\n",
    "            )\n",
    "            for word in sentence\n",
    "        ]\n",
    "\n",
    "        sequences.append(seq)\n",
    "\n",
    "    return sequences #Sequence 변환"
   ]
  },
  {
