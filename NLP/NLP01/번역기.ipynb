    "# 전처리 함수\n",
    "\n",
    "def preprocessing(sentence, lang=\"ko\"):\n",
    "\n",
    "    sentence = sentence.lower().strip()\n",
    "\n",
    "    sentence = re.sub(\n",
    "        r\"([?.!,])\",\n",
    "        r\" \\1 \",\n",
    "        sentence\n",
    "    )\n",
    "\n",
    "    sentence = re.sub(\n",
    "        r\"\\s+\",\n",
    "        \" \",\n",
    "        sentence\n",
    "    )\n",
    "\n",
    "    if lang == \"ko\":\n",
    "\n",
    "        sentence = re.sub(\n",
    "            r\"[^가-힣ㄱ-ㅎㅏ-ㅣa-zA-Z0-9?.!,]+\",\n",
    "            \" \",\n",
    "            sentence\n",
    "        )\n",
    "\n",
    "    else:\n",
    "\n",
    "        sentence = re.sub(\n",
    "            r\"[^a-zA-Z0-9?.!,]+\",\n",
    "            \" \",\n",
    "            sentence\n",
    "        )\n",
    "\n",
    "    sentence = re.sub(\n",
    "        r\"\\s+\",\n",
    "        \" \",\n",
    "        sentence\n",
    "    )\n",
    "\n",
    "    return sentence.strip()"
   ]
