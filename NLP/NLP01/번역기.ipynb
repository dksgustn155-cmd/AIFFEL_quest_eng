    "class Encoder(nn.Module):\n",
    "\n",
    "    def __init__(self, vocab_size, embed_size, hidden_size, dropout=0.3):\n",
    "        super().__init__()\n",
    "\n",
    "        self.embedding = nn.Embedding(\n",
    "            vocab_size,\n",
    "            embed_size,\n",
    "            padding_idx=0\n",
    "        )\n",
    "\n",
    "        self.gru = nn.GRU(\n",
