    "def translate(sentence, max_len=40):\n",
    "    model.eval()\n",
    "\n",
    "    sentence = preprocessing(sentence, lang=\"ko\")\n",
    "    tokens = tokenize_korean(sentence)\n",
    "\n",
    "    seq = [enc_word2idx.get(token, enc_word2idx[\"<unk>\"]) for token in tokens]\n",
    "    seq = seq[:max_len]\n",
    "    seq += [enc_word2idx[\"<pad>\"]] * (max_len - len(seq))\n",
    "\n",
    "    src = torch.tensor(seq, dtype=torch.long).unsqueeze(0).to(device)\n",
    "\n",
    "    with torch.no_grad():\n",
    "        encoder_outputs, hidden = model.encoder(src)\n",
    "        mask = model.create_mask(src)\n",
    "\n",
    "        input_token = torch.tensor(\n",
    "            [dec_word2idx[\"<start>\"]],\n",
    "            dtype=torch.long\n",
    "        ).to(device)\n",
    "\n",
    "        result = []\n",
    "\n",
    "        for _ in range(max_len):\n",
    "            output, hidden, attention = model.decoder(\n",
    "                input_token,\n",
    "                hidden,\n",
    "                encoder_outputs,\n",
    "                mask\n",
    "            )\n",
    "\n",
    "            pred_token = output.argmax(1).item()\n",
    "            pred_word = dec_idx2word.get(pred_token, \"<unk>\")\n",
    "\n",
    "            if pred_word == \"<end>\":\n",
    "                break\n",
    "\n",
    "            if pred_word not in [\"<pad>\", \"<start>\"]:\n",
    "                result.append(pred_word)\n",
    "\n",
    "            input_token = torch.tensor([pred_token], dtype=torch.long).to(device)\n",
    "\n",
    "    return \" \".join(result)"
   ]
  },
  {
   "cell_type": "code",
