   "source": [
    "def pad_sequences(sequences, max_len=40):\n",
    "\n",
    "    padded = []\n",
    "\n",
    "    for seq in sequences:\n",
    "\n",
    "        seq = seq[:max_len]\n",
    "\n",
    "        seq += [0] * (\n",
    "            max_len - len(seq)\n",
    "        )\n",
    "\n",
    "        padded.append(seq)\n",
    "\n",
    "    return np.array(padded) #PADDING" 서로 길이가 다른 문장들을 동일한 길이로 맞춰 batch 학습이 가능하도록 만드는 과정
   ]
